{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://r2ra.local/schema/assessment.schema.json",
  "title": "R2RA Assessment Framework",
  "description": "Schema for an assessment framework such as the JTS Role 2 Readiness Assessment. A framework is the immutable, versioned content definition of a checklist form.",
  "type": "object",
  "required": ["framework_id", "version", "title", "source", "sections"],
  "additionalProperties": false,
  "properties": {
    "framework_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Stable identifier (e.g., 'jts_r2')."
    },
    "version": {
      "type": "string",
      "description": "Framework version (e.g., '2024.0')."
    },
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["authority", "document"],
      "properties": {
        "authority": { "type": "string", "description": "e.g., 'Joint Trauma System' or 'USMC'." },
        "document": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "effective": { "type": "string", "description": "Effective or publication date." },
        "checksum": { "type": "string", "description": "SHA-256 of the source artifact." }
      }
    },
    "preamble": { "type": "string", "description": "Instructional text shown at the top of the form." },
    "classification_notice": { "type": "string" },
    "variables": {
      "type": "array",
      "description": "Top-level form-scoped variables that drive conditional visibility (mission_type, service, component, etc.).",
      "items": { "$ref": "#/$defs/variable" }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    },
    "signoff": {
      "type": "array",
      "description": "Ordered signature blocks at the end of the form.",
      "items": { "$ref": "#/$defs/signature_block" }
    }
  },
  "$defs": {
    "variable": {
      "type": "object",
      "required": ["id", "label", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "label": { "type": "string" },
        "type": { "enum": ["text_short", "text_long", "select_one", "select_multiple", "date"] },
        "required": { "type": "boolean", "default": false },
        "help": { "type": "string" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/option" }
        }
      }
    },
    "option": {
      "type": "object",
      "required": ["value", "label"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "triggers": {
          "type": "array",
          "description": "Section IDs unlocked by selecting this option (e.g., mission_type=arst triggers arsra_appendix).",
          "items": { "type": "string" }
        }
      }
    },
    "section": {
      "type": "object",
      "required": ["id", "ordinal", "title"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)*$" },
        "ordinal": { "type": ["number", "string"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "visible_when": { "$ref": "#/$defs/predicate" },
        "items": { "type": "array", "items": { "$ref": "#/$defs/item" } },
        "sections": { "type": "array", "items": { "$ref": "#/$defs/section" }, "description": "Nested sub-sections." }
      }
    },
    "item": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.]*$" },
        "type": {
          "enum": [
            "binary",
            "select_one",
            "select_multiple",
            "text_short",
            "text_long",
            "date",
            "number",
            "table_yn",
            "table_counts",
            "table_equipment",
            "group",
            "instructional"
          ]
        },
        "prompt": { "type": "string", "description": "Verbatim prompt text from the source." },
        "label": { "type": "string", "description": "Short label, for sub-fields and free-text blocks." },
        "help": { "type": "string" },
        "required": { "type": "boolean", "default": false },
        "visible_when": { "$ref": "#/$defs/predicate" },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/option" }
        },
        "sub_items": {
          "type": "array",
          "description": "For type=group: nested items.",
          "items": { "$ref": "#/$defs/item" }
        },
        "columns": {
          "type": "array",
          "description": "For table_* types.",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "type": { "enum": ["yn", "yn_na", "text", "number", "date"] }
            }
          }
        },
        "rows": {
          "type": "array",
          "description": "For table_* types.",
          "items": {
            "type": "object",
            "required": ["id", "label"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "help": { "type": "string" }
            }
          }
        },
        "capture": {
          "type": "array",
          "description": "Additional fields captured alongside the main response (e.g., training_date on a binary).",
          "items": {
            "type": "object",
            "required": ["id", "label", "type"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "type": { "enum": ["date", "text_short", "text_long", "number"] }
            }
          }
        }
      }
    },
    "predicate": {
      "type": "object",
      "description": "Visibility predicate. Keys are variable IDs; values are allowed values (string or array of strings).",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "array", "items": { "type": "string" } }
        ]
      }
    },
    "signature_block": {
      "type": "object",
      "required": ["role", "label"],
      "properties": {
        "role": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "label": { "type": "string" },
        "visible_when": { "$ref": "#/$defs/predicate" }
      }
    }
  }
}
