    "checksum": "sha256:001492c6bf4d9d2ba980bfaf0e1e90a46ee76218e246262e7f5d1e46833c1e42"
  },
  "preamble": "The purpose is to provide the theater Trauma Medical Director (TMD) with the means to communicate with, and assess a Role 2 unit's readiness for deployment within an operational environment; identify major gaps and determine mitigation strategies with the leaders of the deploying unit. This list is not designed to be comprehensive, TMDs can modify/expand based on mission unique requirements.",
  "classification_notice": "Exercise caution with regards to classification status as this document is completed.",
  "variables": [
    {
      "id": "unique_identifier",
      "label": "Unique identifier",
      "type": "text_short",
      "required": true,
      "help": "See SIPR ID information for actual team ID and location."
    },
    {
      "id": "mission_type",
      "label": "Mission (IAW Joint Publication 4-02, Joint Health Service Support)",
      "type": "select_one",
      "required": true,
      "options": [
        {
          "value": "r2lm_non_split",
          "label": "Role 2 Light Maneuver performing DCS in non split-based operations",
          "description": "Unit's mission is in one location."
        },
        {
          "value": "r2lm_split",
          "label": "Role 2 Light Maneuver performing DCS in split-based operations",
          "description": "Unit's mission is in 2 or more locations."
        },
        {
          "value": "r2e",
          "label": "Role 2 Enhanced",
          "description": "Includes capabilities built around primary surgery (e.g., ICU beds, dental, radiology, lab)."
        },
        {
          "value": "arst",
          "label": "Austere Resuscitative Surgical Team (SOST / GST / GHOST)",
          "description": "Special Operations Surgical Team, Ground Surgical Team, or Golden Hour Offset Surgical Team. Triggers the ARSRA Appendix.",
          "triggers": ["arsra_appendix"]
        }
      ]
    },
    {
      "id": "service",
      "label": "Service",
      "type": "select_one",
      "required": true,
      "options": [
        { "value": "usa", "label": "USA" },
        { "value": "usn", "label": "USN" },
        { "value": "usaf", "label": "USAF" },
        { "value": "coalition", "label": "Coalition Military" },
        { "value": "civilian", "label": "Civilian" },
        { "value": "contract", "label": "Contract" }
      ]
    },
    {
      "id": "component",
      "label": "Component",
      "type": "select_one",
      "required": true,
      "options": [
        { "value": "active", "label": "Active" },
        { "value": "reserve", "label": "Reserve Component" },
        { "value": "national_guard", "label": "National Guard" }
      ]
    }
  ],
  "sections_manifest": [
    { "id": "predeployment_prep", "ordinal": 1, "file": "sections/01_predeployment_prep.json" },
    { "id": "c2",                  "ordinal": 2, "file": "sections/02_command_and_control.json" },
    { "id": "mroe",                "ordinal": 3, "file": "sections/03_mroe.json" },
    { "id": "communications",      "ordinal": 4, "file": "sections/04_communications.json" },
    { "id": "adjacent_support",    "ordinal": 5, "file": "sections/05_adjacent_support.json" },
    { "id": "orsop",               "ordinal": 6, "file": "sections/06_operational_readiness_sops.json" },
    { "id": "clinical_readiness",  "ordinal": 7, "file": "sections/07_clinical_readiness.json" },
    { "id": "clinical_capabilities", "ordinal": 8, "file": "sections/08_clinical_capabilities.json" },
    { "id": "blood_resources",     "ordinal": 9, "file": "sections/09_blood_resources.json" },
    { "id": "team_composition",    "ordinal": 10, "file": "sections/10_team_composition.json" },
    { "id": "critical_supplies",   "ordinal": 11, "file": "sections/11_critical_supplies.json" },
    { "id": "medical_equipment",   "ordinal": 12, "file": "sections/12_medical_equipment.json" },
    { "id": "facilities",          "ordinal": 13, "file": "sections/13_facilities.json" },
    { "id": "closing",             "ordinal": 14, "file": "sections/14_closing.json" },
    { "id": "arsra_appendix",      "ordinal": 15, "file": "sections/15_arsra_appendix.json", "visible_when": { "mission_type": "arst" } }
