{
  "framework_id": "jts_r2",
  "version": "2024.0",
  "title": "Role 2 Readiness Assessment",
  "subtitle": "with ARSRA Appendix",
  "source": {
    "authority": "Joint Trauma System",
    "document": "Role_2_Readiness_Assessment_with_ARSRA_Appendix.docx",
