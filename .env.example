# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=R2RA
DEBUG=false
SECRET_KEY=change-me-use-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
# Dev default: sqlite:///./r2ra_dev.db
# Prod: set this via compose environment override; individual vars below
# are used by docker-compose.prod.yml to build the URL.
DATABASE_URL=postgresql://r2ra:changeme@localhost:5432/r2ra

POSTGRES_USER=r2ra
POSTGRES_PASSWORD=changeme
POSTGRES_DB=r2ra

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOADS_DIR=./uploads
MAX_UPLOAD_BYTES=10485760  # 10 MB

# ── AWS S3 (leave blank to use local disk) ────────────────────────────────────
# GovCloud bucket — must be in us-gov-west-1
AWS_S3_BUCKET=
AWS_REGION=us-gov-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=480  # 8-hour field shift

# ── Content ───────────────────────────────────────────────────────────────────
CONTENT_DIR=../content

# ── Classification ────────────────────────────────────────────────────────────
CUI_BANNER=CONTROLLED UNCLASSIFIED INFORMATION // BASIC
