# EB maps these to environment variables inside the container.
# Set the actual values in the EB console or via `eb setenv` — never commit secrets here.
option_settings:
  aws:elasticbeanstalk:application:environment:
    DATABASE_URL: "placeholder — set in EB console"
    SECRET_KEY: "placeholder — set in EB console"
    S3_EVIDENCE_BUCKET: "placeholder — set in EB console"
    AWS_DEFAULT_REGION: "us-east-1"
    DEBUG: "false"
